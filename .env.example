# ─────────────────────────────────────────────────────────────
# Stitch 6K — Environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Vars prefixed NEXT_PUBLIC_ are exposed to the browser — keep secrets OUT of them.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Razorpay (payments) ───────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
# Server-only secret used to verify payment signatures.
RAZORPAY_KEY_SECRET=
# Secret configured in the Razorpay dashboard webhook settings.
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudinary (images) ───────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
# Server-only secret used to sign upload requests.
CLOUDINARY_API_SECRET=

# ── Upstash Redis (rate limiting) ─────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Redis / BullMQ (background jobs) ──────────────────────────
REDIS_URL=

# ── Resend (transactional email) ──────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Shiprocket (logistics) ────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
# Pre-shared token to authenticate inbound Shiprocket tracking webhooks.
# Set the same value in the Shiprocket dashboard webhook config (x-api-key).
SHIPROCKET_WEBHOOK_TOKEN=

# ── Admin access ──────────────────────────────────────────────
# Comma-separated list of emails allowed into /admindashboard.
ADMIN_EMAILS=

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://the6k.com

# ── Error monitoring (Sentry) ─────────────────────────────────
# DSN from your Sentry project. Exposed to the client for browser error capture.
NEXT_PUBLIC_SENTRY_DSN=
# Optional: server-only DSN (falls back to NEXT_PUBLIC_SENTRY_DSN if unset).
SENTRY_DSN=

# ── Dev tooling ───────────────────────────────────────────────
# Set to "false" in production to disable the dev-only test-runner route.
NEXT_PUBLIC_ENABLE_DEV_TOOLS=false
