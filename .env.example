# ─────────────────────────────────────────────────────────────
# Stitch 6K — Environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Vars prefixed NEXT_PUBLIC_ are exposed to the browser — keep secrets OUT of them.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Razorpay (payments) ───────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
# Server-only secret used to verify payment signatures.
RAZORPAY_KEY_SECRET=
# Secret configured in the Razorpay dashboard webhook settings.
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudinary (images) ───────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
# Server-only secret used to sign upload requests.
CLOUDINARY_API_SECRET=

# ── Upstash Redis (rate limiting) ─────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Redis / BullMQ (background jobs) ──────────────────────────
REDIS_URL=

# ── Resend (transactional email) ──────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Brevo SMTP (transactional email) ──────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# ── Shiprocket (logistics) ────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
# Pre-shared token to authenticate inbound Shiprocket tracking webhooks.
# Set the same value in the Shiprocket dashboard webhook config (x-api-key).
SHIPROCKET_WEBHOOK_TOKEN=
SHIPROCKET_PICKUP_PINCODE=620018

# ── Admin access ──────────────────────────────────────────────
# Comma-separated list of emails allowed into /admindashboard.
ADMIN_EMAILS=

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://the6k.com

# ── Error monitoring (Sentry) ─────────────────────────────────
# DSN from your Sentry project. Exposed to the client for browser error capture.
NEXT_PUBLIC_SENTRY_DSN=
# Optional: server-only DSN (falls back to NEXT_PUBLIC_SENTRY_DSN if unset).
SENTRY_DSN=

# ── Support & Store Details ───────────────────────────────────
NEXT_PUBLIC_SUPPORT_EMAIL=6kthebrand@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE=919363693004
SHIPROCKET_PICKUP_PHONE=9363693004

# ── Feature Flags & Development Toggles ────────────────────────
DISABLE_REDIS_CACHE=false
# Set to true ONLY in local development
# Never set on staging or production
ENABLE_DEV_TEST_ACTIONS=false
# Set to true ONLY on the dedicated VPS worker process (npm run worker).
# Never set this on the Next.js server — it will start BullMQ workers inside SSR.
IS_WORKER=false
# Set to true to show manual shipping override 
# buttons for testing. Never use in production.
NEXT_PUBLIC_ENABLE_MOCK_SHIPPING=false

# ── Google Analytics & Advertising ────────────────────────────
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_LABEL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA4_API_SECRET=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
